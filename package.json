{
  "name": "swe-forge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c teal,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "npm --prefix server run dev",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "start:api": "npm --prefix server run start",
    "scaffold:content": "node --import tsx scripts/scaffold-content.ts",
    "migrate:content": "node --import tsx scripts/migrate-to-content.ts",
    "finish:expand-deep": "node --import tsx scripts/finish-expand-deep.ts"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
